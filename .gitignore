node_modules/
**/bin/
**/obj/
# Local pre-commit tool cache (nuget-check installed via dotnet tool install --tool-path)
.dependably-tools/
# Built Svelte output is generated into wwwroot/ — ignore everything except the
# vendored Swagger UI bundle (checked in to replace the external CDN load).
src/Dependably/wwwroot/*
!src/Dependably/wwwroot/swagger/
.env.deploy
dotnet-install.sh
**/.DS_Store
.claude/
CLAUDE.local.md
*.binlog
sbom-backend.json
web/sbom-frontend.json

# Test + coverage outputs (generated)
tests/**/TestResults/
test-results/
web/coverage/
cov-out/
**/*.cobertura.xml

# Roslyn / .NET build cache files emitted by analyzers — never artefacts of source code.
*.lscache
