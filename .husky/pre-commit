# Frontend: run lint-staged against staged web/ files (subshell keeps cwd at repo root).
(cd web && npx lint-staged) || exit 1

# Backend: when C# or build-config files are staged, build with warnings-as-errors so the
# analyzer/compiler warnings that gate CI (TreatWarningsAsErrors when CI=true) also fail the
# commit locally. NU1900 (offline vuln-data fetch noise) stays excluded via Directory.Build.props.
staged_dotnet=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cs|csproj|props|targets)$' || true)
if [ -n "$staged_dotnet" ]; then
  # Auto-format staged C# to the .editorconfig rules (same checks the CI dotnet-format job
  # verifies), then re-stage so the commit matches what CI will accept. Scoped to staged .cs
  # via --include so unrelated files are untouched. NOTE: re-staging adds the whole file, so
  # avoid partial (`git add -p`) staging of a .cs file you don't want fully committed.
  staged_cs=$(printf '%s\n' "$staged_dotnet" | grep -E '\.cs$' || true)
  if [ -n "$staged_cs" ]; then
    echo "Formatting staged C# (dotnet format whitespace + style)…"
    # shellcheck disable=SC2086
    dotnet format whitespace --include $staged_cs --no-restore || exit 1
    # shellcheck disable=SC2086
    dotnet format style --include $staged_cs || exit 1
    # shellcheck disable=SC2086
    git add $staged_cs
  fi

  echo "Building with warnings-as-errors…"
  if ! dotnet build -c Debug -p:TreatWarningsAsErrors=true --nologo -v quiet; then
    echo "✗ Build failed or emitted warnings. Fix them before committing (CI rejects warnings)."
    exit 1
  fi
fi

# Supply-chain: audit dependency manifests with the dependably checkers when they change.
# @dependably/npm-check runs on the npm lockfile; nuget-check (a pinned local dotnet tool)
# runs on the backend packages.lock.json files. Both surface known vulnerabilities and any
# package source/registry host that isn't public or allowlisted in the repo-root
# .dependably-check config. Both tools live on the private dogfood feed, so the checks need
# DEPENDABLY_TOKEN; without it they are skipped (a warning, not a failure) so contributors
# without feed access can still commit. CI enforces them regardless.
staged_npm_deps=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^web/package(-lock)?\.json$' || true)
staged_nuget_deps=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(\.csproj|packages\.lock\.json|(^|/)nuget\.config)$' || true)

if [ -n "$staged_npm_deps" ] || [ -n "$staged_nuget_deps" ]; then
  if [ -z "${DEPENDABLY_TOKEN:-}" ]; then
    echo "⚠ Skipping dependably dependency checks: DEPENDABLY_TOKEN not set (private feed unavailable). CI will still enforce them."
  else
    if [ -n "$staged_npm_deps" ]; then
      echo "Auditing web/package-lock.json (@dependably/npm-check)…"
      if ! npx -y @dependably/npm-check@1.6.0 audit web/package-lock.json; then
        echo "✗ npm-check found issues. Fix them, or allowlist a host in .dependably-check."
        exit 1
      fi
    fi
    if [ -n "$staged_nuget_deps" ]; then
      # nuget-check is a private, dev-only tool — install it into a local, never-committed
      # path rather than the shared .config/dotnet-tools.json (which CI restores and must not
      # depend on the private feed). Cached after first install. .git is a file in worktrees,
      # so use a gitignored top-level dir for worktree compatibility.
      nuget_check=".dependably-tools/nuget-check"
      if [ ! -x "$nuget_check" ]; then
        echo "Installing nuget-check (dependably tool feed)…"
        dotnet tool install Dependably.NuGetCheck --version 1.1.0 \
          --tool-path .dependably-tools \
          --configfile .config/dependably-tools.nuget.config >/dev/null 2>&1 \
          || echo "⚠ Skipping nuget-check: tool install failed (dogfood feed or DEPENDABLY_TOKEN issue)."
      fi
      if [ -x "$nuget_check" ]; then
        for lock in src/Dependably/packages.lock.json tests/Dependably.Tests/packages.lock.json; do
          [ -f "$lock" ] || continue
          echo "Auditing $lock (nuget-check)…"
          if ! "$nuget_check" "$lock" --source osv; then
            echo "✗ nuget-check found issues in $lock. Fix them, or allowlist a host in .dependably-check."
            exit 1
          fi
        done
      fi
    fi
  fi
fi
