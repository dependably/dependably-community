<?xml version="1.0" encoding="utf-8"?>
<!--
  Project-level NuGet sources for local development. <clear /> wipes inherited sources
  from the user's global ~/.nuget/NuGet/NuGet.Config so dotnet restore only talks to
  api.nuget.org. This avoids hangs when the private dependably proxy is unreachable or
  serves an incomplete version list (the very bug this repo is fixing).

  The Dockerfile does not copy this file, so container builds are unaffected.

  Production deployments should set their NuGet feed via env/config in the runtime
  environment, not this file.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
