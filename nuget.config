<?xml version="1.0" encoding="utf-8"?>
<!--
  Project-level NuGet sources for local development. <clear /> wipes any sources
  inherited from the user's global ~/.nuget/NuGet/NuGet.Config so dotnet restore
  resolves exclusively against api.nuget.org, giving deterministic local builds
  regardless of any private feeds configured on the machine.

  The Dockerfile does not copy this file, so container builds are unaffected.

  Production deployments should set their NuGet feed via env/config in the runtime
  environment, not this file.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
