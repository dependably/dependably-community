{
  "name": "web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "cd .. && husky || true",
    "lint": "eslint src",
    "lint:css": "stylelint \"src/**/*.{svelte,css}\"",
    "format": "prettier --write src",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=test-results/junit.xml",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:debug": "playwright test --config e2e/playwright.config.ts --debug",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "sbom": "cyclonedx-npm --output-format json --output-file sbom-frontend.json",
    "sbom:prod": "cyclonedx-npm --omit dev --output-format json --output-file sbom-frontend-prod.json"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "fast-uri": "^3.1.2",
    "undici": "^7.28.0",
    "js-yaml": "^4.2.0",
    "tar": "^7.5.16"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true,
    "libxmljs2": true,
    "es5-ext": true
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "5.0.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.7.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "36.0.1",
    "svelte": "5.56.3",
    "svelte-check": "4.4.8",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.16",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "src/**/*.{js,svelte}": "eslint --no-warn-ignored"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "@zxcvbn-ts/language-en": "3.0.2",
    "svelte-i18n": "4.0.1"
  }
}
